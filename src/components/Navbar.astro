<script>
  import { getBrowserClient } from '@/lib/supabase';
  // AÑADIDO: getUserProfile a las importaciones
  import { getCurrentUser, getUserRole, getUserProfile } from '@/lib/auth';

  // Usamos un IIFE para ejecutar la sesión inmediatamente
  (async () => {
    const supabase = getBrowserClient();
    const { data: { session } } = await supabase.auth.getSession();
    
    const userMenu = document.getElementById('user-menu');
    const loginButton = document.getElementById('login-button');
    const userAvatar = document.getElementById('user-avatar');
    const mobileUserLinks = document.getElementById('mobile-user-links');
    const mobileLoginLink = document.getElementById('mobile-login-link');

    if (session) {
      // Usamos un esqueleto o placeholder mientras cargamos el perfil
      if (userAvatar) userAvatar.textContent = '...';
      userMenu?.classList.remove('hidden');
      userMenu?.classList.add('flex');
      loginButton?.classList.add('hidden');

      const user = await getCurrentUser();
      
      // ✅ CORRECCIÓN: Ahora sí obtenemos el perfil del usuario
      const profile = user ? await getUserProfile(user.id) : null;
      const role = user ? await getUserRole(user.id) : null;

      if (userAvatar) {
        // Ahora 'profile' ya existe y podemos usar full_name
        const initials = (profile?.full_name || user?.email || 'U')
          .split(' ')
          .map((n: string) => n[0])
          .join('')
          .slice(0, 2)
          .toUpperCase();
        userAvatar.textContent = initials;
      }
      mobileUserLinks?.classList.remove('hidden');
      mobileLoginLink?.classList.add('hidden');
    } else {
      loginButton?.classList.remove('hidden');
      loginButton?.classList.add('block');
      mobileLoginLink?.classList.remove('hidden');
    }
  })();
</script>
